# ============================================
# Variables de Entorno para Docker Compose
# Copia este archivo a .env y ajusta los valores
# ============================================

# --- PostgreSQL ---
POSTGRES_DB=herramientas_app
POSTGRES_USER=sys
POSTGRES_PASSWORD=DB123
DB_PORT_EXTERNAL=5432

# --- Backend (Node API) ---
API_PORT=3000
NODE_ENV=production
DB_SYNC_ALTER=false
JWT_SECRET=cambiar-por-un-secreto-seguro
CORS_ORIGIN=http://localhost:5173

# --- Frontend (React + Vite) ---
FRONTEND_PORT=80

# ============================================
# Notas para Coolify:
# - Las variables DB_HOST y DB_PORT del backend
#   apuntan al servicio interno "db:5432"
# - CORS_ORIGIN debe apuntar al dominio público
#   del frontend (ej: https://tudominio.com)
# - JWT_SECRET debe ser un valor único y seguro
# ============================================
